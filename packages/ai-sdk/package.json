{
  "name": "@gsengai/ai-sdk",
  "version": "0.2.0",
  "private": false,
  "description": "Evidence-logging LanguageModelMiddleware for the Vercel AI SDK (ai@7). Supports compliance with EU AI Act Article 50 and California SB 942; never mutates or blocks model responses. Not legal advice.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@gsengai/core": "workspace:^"
  },
  "peerDependencies": {
    "ai": "^7.0.0"
  },
  "devDependencies": {
    "ai": "^7.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "author": "Dominik Ertl",
  "keywords": [
    "eu-ai-act",
    "ai-act",
    "article-50",
    "sb-942",
    "ai-transparency",
    "ai-disclosure",
    "ai-compliance",
    "content-provenance",
    "vercel-ai-sdk",
    "ai-sdk",
    "middleware",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gsengai/gsengai.git",
    "directory": "packages/ai-sdk"
  },
  "homepage": "https://github.com/gsengai/gsengai/tree/main/packages/ai-sdk#readme",
  "bugs": "https://github.com/gsengai/gsengai/issues",
  "publishConfig": {
    "access": "public"
  }
}
